{
  "name": "tinysuite-pinpoint",
  "displayName": "Pinpoint: Copy Frontend Context for AI",
  "description": "Pick any frontend element in VS Code's Integrated Browser and capture its HTML and CSS context for AI coding agents.",
  "version": "0.2.0",
  "publisher": "marcellm01",
  "license": "MIT",
  "icon": "resources/icon.png",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1F2328",
    "theme": "dark"
  },
  "homepage": "https://github.com/MarcellM01/Pinpoint",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcellM01/Pinpoint.git"
  },
  "bugs": {
    "url": "https://github.com/MarcellM01/Pinpoint/issues"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "browser",
    "codex",
    "copilot",
    "css",
    "devtools",
    "dom",
    "element",
    "frontend",
    "html",
    "selector",
    "clipboard",
    "screenshot"
  ],
  "main": "./extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Pinpoint attaches VS Code's JavaScript debugger to the Integrated Browser and writes capture reports to the workspace."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "pinpoint.pick",
        "title": "Pinpoint: Pick Element",
        "category": "Browser",
        "enablement": "activeEditor == workbench.editor.browser",
        "icon": {
          "light": "resources/pick-light.svg",
          "dark": "resources/pick-dark.svg"
        }
      },
      {
        "command": "pinpoint.stop",
        "title": "Pinpoint: Stop Picking",
        "category": "Browser",
        "enablement": "activeEditor == workbench.editor.browser && pinpoint.armed",
        "icon": "$(stop-circle)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pinpoint.pick",
          "group": "navigation@1",
          "when": "activeEditor == workbench.editor.browser && !pinpoint.armed"
        },
        {
          "command": "pinpoint.stop",
          "group": "navigation@1",
          "when": "activeEditor == workbench.editor.browser && pinpoint.armed"
        }
      ],
      "commandPalette": [
        {
          "command": "pinpoint.stop",
          "when": "pinpoint.armed"
        }
      ]
    }
  },
  "files": [
    "extension.js",
    "picker.js",
    "vendor",
    "resources",
    "README.md",
    "CHANGELOG.md",
    "SUPPORT.md",
    "SECURITY.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ]
}
